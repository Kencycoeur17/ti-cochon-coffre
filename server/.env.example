# Ti Cochon Coffre — SQLite MVP server config
APP_MODE=prototype
PORT=3000

# SQLite database location
DB_PATH=./ti-cochon.sqlite

# Auth/session settings
SESSION_DAYS=7
PBKDF2_ITERATIONS=120000

# Shared development API key used only for legacy/prototype compatibility routes.
# Do not expose this in a production frontend.
API_KEY=change-me-long-random-dev-key

# CORS
# Use * for local demos, or your exact frontend URL for hosted tests.
ALLOWED_ORIGIN=*

# Optional SMTP notifications
# If these values are empty, email notifications are skipped safely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ADMIN_EMAIL=

# Ledger note
# Current MVP uses SQLite. For production, use managed PostgreSQL + backups.
LEDGER_STRICT=true
