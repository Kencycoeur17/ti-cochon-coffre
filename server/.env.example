# Ti Cochon Coffre — prototype server config
APP_MODE=prototype
PORT=3000

# Shared development API key used by the frontend when backend mode is enabled.
# Generate a long random value for local/demo tests.
API_KEY=change-me-long-random-dev-key

# CORS
# Use * for local demos, or your exact frontend URL for hosted tests.
ALLOWED_ORIGIN=*

# Optional SMTP notifications
# If these values are empty, email notifications are skipped safely.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ADMIN_EMAIL=

# Ledger note
# Current prototype uses server/server-data.json as file storage.
# Replace with PostgreSQL/SQLite before production.
LEDGER_STRICT=true
